# ─────────────────────────────────────────────
#  AI Shorts Generator — Environment Variables
# ─────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=alloy           # alloy | echo | fable | onyx | nova | shimmer
OPENAI_WHISPER_MODEL=whisper-1

# ── Pexels (stock video) ────────────────────
PEXELS_API_KEY=your_pexels_key_here

# ── Pixabay (fallback stock) ────────────────
PIXABAY_API_KEY=your_pixabay_key_here

# ── ElevenLabs (premium TTS, optional) ──────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Backend ─────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change_me_in_production_32chars_min
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Queue / Redis ───────────────────────────
REDIS_URL=redis://localhost:6379/0
MAX_CONCURRENT_RENDERS=2

# ── Storage ─────────────────────────────────
EXPORTS_DIR=./exports
ASSETS_DIR=./assets
TEMP_DIR=./tmp

# ── Video ───────────────────────────────────
FFMPEG_PATH=ffmpeg                # or full path e.g. C:/ffmpeg/bin/ffmpeg.exe
GPU_ACCELERATION=false            # true = use NVENC/VAAPI when available
DEFAULT_FPS=30
DEFAULT_RESOLUTION=1080x1920

# ── Features ────────────────────────────────
ENABLE_BATCH_RENDER=true
ENABLE_LOCAL_AI=false             # use Ollama locally instead of OpenAI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
